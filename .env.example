# ============================================================
# LedgeAI 環境変数設定ファイル
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
# ============================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=ledge_ai_dev
MYSQL_USER=ledge_user
MYSQL_PASSWORD=your_password_here

# --- Rails ---
DATABASE_URL=mysql2://ledge_user:your_password_here@db:3306/ledge_ai_dev
RAILS_ENV=development
